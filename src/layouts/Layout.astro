---
import "../styles/global.css";

const { title = "Gabriella Scott" } = Astro.props;

const tabs = [
  { href: "/",        label: "Projects" },
  { href: "/about",   label: "About me" },
  { href: "/hobbies", label: "Hobbies" },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-cream text-ink">
    <header class="border-b border-ink/10">
      <div class="mx-auto max-w-3xl px-6 py-6">
        <p class="text-lg font-semibold tracking-tight">Gabriella Scott</p>
        <nav class="mt-4 flex gap-2">
          {tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={[
                "rounded-full px-4 py-1.5 text-sm font-medium transition-colors",
                current === tab.href
                  ? "bg-mint text-ink"
                  : "bg-sky/40 text-ink/70 hover:bg-sky",
              ]}
            >
              {tab.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-12">
      <slot />
    </main>
  </body>
</html>