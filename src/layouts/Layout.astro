---
import "../styles/global.css";

const { title = "Gabriella Scott" } = Astro.props;

const tabs = [
  { href: "/about",   label: "About me" },
  { href: "/",        label: "Projects" },
  { href: "/adventures", label: "Adventures" },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/Favicon_flower.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-cream text-ink">
    <header class="relative overflow-hidden border-b border-ink/10" style="height: 12.5vh;">
      <!-- Decorative background title -->
      <p
        class="absolute inset-0 flex items-center justify-center whitespace-nowrap pointer-events-none select-none leading-none"
        style="font-family: 'Great Vibes', cursive; font-size: 7vw; color: #C4D7F2; -webkit-text-stroke: 2px #C4D7F2;"
      >
        Gabriella Scott
      </p>
      <!-- Nav sits on top -->
      <div class="relative z-10 mx-auto max-w-3xl px-6 h-full flex items-end pb-3">
        <nav class="flex gap-2">
          {tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={[
                "rounded-full px-4 py-1.5 text-sm font-medium transition-colors",
                current === tab.href
                  ? "bg-mint text-ink"
                  : "bg-sky/40 text-ink/70 hover:bg-sky",
              ]}
            >
              {tab.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-12">
      <slot />
    </main>
  </body>
</html>