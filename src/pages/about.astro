---
import Layout from "../layouts/Layout.astro";
---
<Layout title="About me — Gabriella Scott">
  <!-- Hero: intro + photo -->
  <section class="relative overflow-x-clip">
    <!-- decorative soft blobs -->
    <div aria-hidden="true" class="pointer-events-none absolute -top-10 -left-12 -z-10 h-56 w-56 rounded-full bg-sky/50 blur-3xl"></div>
    <div aria-hidden="true" class="pointer-events-none absolute top-24 -right-8 -z-10 h-48 w-48 rounded-full bg-mint/50 blur-3xl"></div>

    <div class="flex flex-col items-center gap-10 md:flex-row md:items-start md:gap-12">
      <div class="fade-up flex-1">
        <h1 class="flex items-center gap-2 text-3xl font-bold tracking-tight">
          About me
          <span class="text-mint">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5">
              <path d="M12 2l1.8 6.2L20 10l-6.2 1.8L12 18l-1.8-6.2L4 10l6.2-1.8z" />
            </svg>
          </span>
        </h1>
        <p class="mt-4 text-ink/80 leading-relaxed">
          I'm a BScHons Computer Science student at Stellenbosch University, having completed my
          undergraduate BSc in Computer Science at the same institution.
        </p>
        <p class="mt-4 text-ink/80 leading-relaxed">
          My primary interests lie in software development and engineering, with a particular
          appreciation for the human-computer interaction side of building software. I'm also
          passionate about AI, and I'm looking forward to diving deeper into machine learning
          this coming semester. I have some experience in web development as well.
        </p>
      </div>

      <!-- polaroid -->
      <figure class="fade-up shrink-0 -rotate-3 rounded-md bg-white p-3 shadow-xl transition-transform duration-300 ease-out hover:rotate-0 hover:scale-[1.02] motion-safe:md:mt-2" style="animation-delay:.15s">
        <img
          src="/gabriella.jpg"
          alt="Gabriella in an apple orchard on a sunny day"
          class="h-72 w-56 rounded-sm object-cover"
        />
        <figcaption class="caption pt-2 text-center text-2xl text-ink/70">sunshine &amp; apples 🍏</figcaption>
      </figure>
    </div>
  </section>

  <h2 class="mt-14 flex items-center gap-2.5 text-xl font-semibold tracking-tight">
    <span class="h-5 w-1.5 rounded-full bg-mint"></span>
    Career goals
  </h2>
  <p class="mt-4 text-ink/80 leading-relaxed">
    I'm looking for a role where I can grow as a software engineer while working closely
    with a team — collaboration and being around people matter a great deal to me, so I'm
    drawn to in-office or hybrid roles rather than fully remote ones. Beyond that I'm keeping
    an open mind: I care more about joining a place where I can keep learning, contribute
    meaningfully, and work on problems I find interesting than about locking myself into a
    single niche this early. Software development, HCI, and AI/ML are the areas I'm most
    excited to move toward.
  </p>

  <h2 class="mt-14 flex items-center gap-2.5 text-xl font-semibold tracking-tight">
    <span class="h-5 w-1.5 rounded-full bg-sky"></span>
    Key skills
  </h2>
  <div class="mt-4 flex flex-col gap-5">
    <div>
      <h3 class="text-sm font-medium text-ink/60">Languages</h3>
      <ul class="mt-2 flex flex-wrap gap-2 text-sm">
        <li class="rounded-full bg-sky/40 px-3 py-1">Python</li>
        <li class="rounded-full bg-sky/40 px-3 py-1">Java</li>
        <li class="rounded-full bg-sky/40 px-3 py-1">C#</li>
        <li class="rounded-full bg-sky/40 px-3 py-1">JavaScript</li>
        <li class="rounded-full bg-sky/40 px-3 py-1">TypeScript</li>
        <li class="rounded-full bg-sky/40 px-3 py-1">HTML</li>
        <li class="rounded-full bg-sky/40 px-3 py-1">CSS</li>
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-medium text-ink/60">Frameworks &amp; libraries</h3>
      <ul class="mt-2 flex flex-wrap gap-2 text-sm">
        <li class="rounded-full bg-mint/50 px-3 py-1">Astro</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Tailwind CSS</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Flask</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">React</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Next.js</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">.NET MAUI</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">pandas</li>
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-medium text-ink/60">Tools &amp; platforms</h3>
      <ul class="mt-2 flex flex-wrap gap-2 text-sm">
        <li class="rounded-full bg-mint/50 px-3 py-1">Git &amp; GitHub</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">GitLab</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Node.js / npm</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Linux (Ubuntu)</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Azure</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Firebase</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Twilio</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">SQLite</li>
        <li class="rounded-full bg-mint/50 px-3 py-1">Maven</li>
      </ul>
    </div>
  </div>

  <h2 class="mt-14 flex items-center gap-2.5 text-xl font-semibold tracking-tight">
    <span class="h-5 w-1.5 rounded-full bg-mint"></span>
    Get in touch
  </h2>
  <ul class="mt-3 flex flex-col gap-2.5 text-sm">
    <li>
      <a href="mailto:gabriella.scott.sa@gmail.com" class="inline-flex items-center gap-2.5 text-ink/70 hover:text-ink transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-4 w-4 shrink-0">
          <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
          <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
        </svg>
        <span class="underline underline-offset-2">gabriella.scott.sa@gmail.com</span>
      </a>
    </li>
    <li>
      <a href="https://www.linkedin.com/in/gabriella-scott-gs/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 text-ink/70 hover:text-ink transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-4 w-4 shrink-0">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM7.119 20.452H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" />
        </svg>
        <span class="underline underline-offset-2">LinkedIn — gabriella-scott-gs</span>
      </a>
    </li>
    <li>
      <a href="https://github.com/Gabriella-Scott" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 text-ink/70 hover:text-ink transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-4 w-4 shrink-0">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
        </svg>
        <span class="underline underline-offset-2">GitHub — Gabriella-Scott</span>
      </a>
    </li>
  </ul>
</Layout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap");

  .caption {
    font-family: "Caveat", ui-rounded, cursive;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fade-up 0.6s ease both; }

  @media (prefers-reduced-motion: reduce) {
    .fade-up { animation: none; }
  }
</style>