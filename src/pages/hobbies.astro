---
import Layout from "../layouts/Layout.astro";

const adventures = [
  {
    title: "Example adventure title",
    date: "March 2025",
    location: "Somewhere worth remembering",
    body:
      "A short paragraph or two about the experience — what happened, what stuck " +
      "with you, and why it mattered. Keep it personal and specific; one vivid " +
      "detail beats three generic ones.",
  },
  // Duplicate the block above for each new adventure.
];
---

<Layout title="Hobbies — Gabriella Scott">
  <h1 class="text-3xl font-bold tracking-tight">Hobbies</h1>

  <p class="mt-3 max-w-2xl text-ink/70">
    Intro paragraph goes here — a sentence or two on the side of you that doesn't
    fit on a CV. Why you share these, and what you tend to chase in your free time.
  </p>

  <section class="mt-12">
    <h2 class="border-l-4 border-mint pl-3 text-2xl font-semibold tracking-tight">
      Adventures
    </h2>
    <p class="mt-2 max-w-2xl text-ink/70">
      Small stories from things I've done and places I've been.
    </p>

    <div class="mt-8 space-y-8">
      {adventures.map((a) => (
        <article class="fade-up rounded-2xl bg-sky/20 p-6">
          <div class="flex flex-wrap items-baseline gap-x-3">
            <h3 class="text-xl font-semibold">{a.title}</h3>
            <span class="font-handwriting text-lg text-ink/60">{a.location}</span>
          </div>
          <p class="mt-1 text-sm text-ink/50">{a.date}</p>
          <p class="mt-3 leading-relaxed text-ink/80">{a.body}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .fade-up { animation: fade-up 0.6s ease-out both; }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .fade-up { animation: none; }
  }
</style>